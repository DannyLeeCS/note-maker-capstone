<!-- The header for this page -->
<%- include("partials/header.ejs") %>

<!-- Overall container for the form and hero image -->
<div class="container d-flex justify-content-between align-items-center">
  <!-- Input form on the left -->
  <div class="form-container">
    <h1>Your Truly Note Maker</h1>
    <form action="/submit" method="post">
        <!-- Label for the text input -->
        <label for="largeText" class="label">Power your creativity</label><br><br>

        <!-- Textarea for input -->
        <textarea id="largeText" name="userNote" rows="10" cols="50" placeholder="Type your content here..."></textarea>
        <br><br>

        <!-- Submit button -->
        <button type="submit" class="btn btn-primary border-0" style="background-color:#347928">Post Note</button>
        
        <!-- All posts button -->
        <a href="/post">
          <button type="button" class="btn btn-primary border-0" style="background-color:#7de36b; color: black">All notes</button>
        </a>
    </form>
  </div>

  <!-- Hero image on home page -->
  <div class="image-container">
    <base href="/">
    <img src="assets/image.png" alt="Creative Image" class="img-fluid" style="max-width: 100%; height: auto;">
  </div>
</div>

<!-- This page's footer -->
<%- include("partials/footer.ejs") %>
